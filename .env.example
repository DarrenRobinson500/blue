# Django
SECRET_KEY=django-insecure-change-me-in-production
DEBUG=True
ALLOWED_HOSTS=localhost,127.0.0.1

# Database — single connection acceptable for Phase 1 development
# See DATABASE_SETUP.md for role separation (required before production)
DB_NAME=lifeplatform
DB_HOST=localhost
DB_PORT=5432
DB_USER=postgres
DB_PASSWORD=

# Application roles (used when role separation is enforced)
RISK_DB_USER=risk_app
RISK_DB_PASSWORD=

ACTUARIAL_DB_USER=actuarial_app
ACTUARIAL_DB_PASSWORD=

# CORS — comma-separated origins for both Vite dev servers and production
CORS_ALLOWED_ORIGINS=http://localhost:5173,http://localhost:5174

# Seed admin credentials
ADMIN_EMAIL=admin@lifeplatform.com.au
ADMIN_PASSWORD=
